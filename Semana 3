    // FUSIÓN
    public static int[] fusionar(int[] a, int[] b) {
        int[] fusion = new int[a.length + b.length];
        int i = 0;
        // copiar primer arreglo
        for (int j = 0; j < a.length; j++) {
            fusion[i] = a[j];
            i++;
        }
        // copiar segundo arreglo
        for (int j = 0; j < b.length; j++) {
