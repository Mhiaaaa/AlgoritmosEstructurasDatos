public class Ejercicio 
{
// Método para comparar arreglos
    public static boolean compararArreglos(int[] a, int[] b) {
        if (a.length != b.length) return false;

        for (int i = 0; i < a.length; i++) {
            if (a[i] != b[i]) return false;
        }
        return true;
    }
    // Método para clonar un arreglo
    public static int[] clonarArreglo(int[] original) {
        int[] copia = new int[original.length];

        for (int i = 0; i < original.length; i++) {
            copia[i] = original[i];
        }
        return copia;
    }
    // Método para fusionar arreglos
    public static int[] fusionarArreglos(int[] a, int[] b) {
        int[] fusion = new int[a.length + b.length];

        for (int i = 0; i < a.length; i++) {
            fusion[i] = a[i];
        }
        for (int i = 0; i < b.length; i++) {
            fusion[a.length + i] = b[i];
        }
        return fusion;
    }
    // Método para mostrar un arreglo
    public static void mostrarArreglo(int[] arr) {
        for (int i = 0; i < arr.length; i++) {
            System.out.print(arr[i] + " ");
        }
        System.out.println();
    }
    public static void main(String[] args) {

        int[] arreglo1 = {1, 2, 3, 4};
        int[] arreglo2 = {1, 2, 3, 4};

        // Comparación
        System.out.println("¿Los arreglos son iguales? " + compararArreglos(arreglo1, arreglo2));

        // Clonación
        int[] clon = clonarArreglo(arreglo1);
        clon[0] = 99;

        System.out.println("Arreglo original:");
        mostrarArreglo(arreglo1);

        System.out.println("Arreglo clonado modificado:");
        mostrarArreglo(clon);

        // Fusión
        int[] fusion = fusionarArreglos(arreglo1, arreglo2);

        System.out.println("Arreglo fusionado:");
        mostrarArreglo(fusion);
    }
}
En este ejercicio realicé un programa en Java llamado Ejercicio, donde trabajo
con arreglos unidimensionales y aplico tres operaciones importantes: comparación, clonación y fusión
Con este programa demuestro cómo se pueden manipular arreglos aplicando comparación, 
clonación y fusión, entendiendo cómo recorrerlos y cómo trabajar con copias y combinaciones de datos
